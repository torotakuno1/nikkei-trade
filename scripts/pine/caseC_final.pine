//@version=5
strategy("案C PKG A + LDN16 + VT1", 
     overlay=true,
     initial_capital=920000,
     default_qty_type=strategy.fixed,
     default_qty_value=2,
     currency=currency.JPY,
     commission_type=strategy.commission.cash_per_order,
     commission_value=50,
     slippage=1,
     pyramiding=0,
     calc_on_every_tick=false)

// ============================================================
// パッケージA固定
// ============================================================
i_minScore = 2
i_stopLoss = 300
i_adxThresh = 20
i_bbSigma = 0.6
i_requireADXRising = false

i_macdFast    = 12
i_macdSlow    = 26
i_macdSignal  = 9
i_rsiLen      = 14
i_diLen       = 14
i_adxSmooth   = 14
i_kvoFast     = 34
i_kvoSlow     = 55
i_stdLen      = 26
i_bbLen       = 21
i_dmaLen      = 20

// ============================================================
// VIXターム構造フィルター（VT1: VR>1.00）
// ============================================================
vixClose   = request.security("CBOE:VIX",   "D", close)
vix3mClose = request.security("CBOE:VIX3M", "D", close)
vixRatio   = vix3mClose / vixClose
vixOK      = vixRatio > 1.00

// ============================================================
// 時間帯フィルター（ロンドンフィックス除外）
// ============================================================
hourLDN = hour(time, "Europe/London")
sessionOK = hourLDN != 16

// ============================================================
// 平均足
// ============================================================
haClose = (open + high + low + close) / 4
var float haOpen = na
haOpen := na(haOpen[1]) ? (open + close) / 2 : (haOpen[1] + haClose[1]) / 2
haBullish = haClose > haOpen
haBearish = haClose < haOpen

// ============================================================
// NTインジケーター
// ============================================================
[macdLine, signalLine, macdHist] = ta.macd(close, i_macdFast, i_macdSlow, i_macdSignal)
rsiVal = ta.rsi(close, i_rsiLen)
[diPlus, diMinus, adxVal] = ta.dmi(i_diLen, i_adxSmooth)

kvo_trend = ta.change(hlc3) > 0 ? volume : -volume
kvo_fast  = ta.ema(kvo_trend, i_kvoFast)
kvo_slow  = ta.ema(kvo_trend, i_kvoSlow)
kvo       = kvo_fast - kvo_slow

sig_macd = macdHist > 0 ? 1 : macdHist < 0 ? -1 : 0
sig_rsi  = rsiVal > 50 ? 1 : rsiVal < 50 ? -1 : 0
sig_di   = diPlus > diMinus ? 1 : diPlus < diMinus ? -1 : 0
sig_kvo  = kvo > 0 ? 1 : kvo < 0 ? -1 : 0

scoreLong  = (sig_macd == 1 ? 1 : 0) + (sig_rsi == 1 ? 1 : 0) + (sig_di == 1 ? 1 : 0) + (sig_kvo == 1 ? 1 : 0)
scoreShort = (sig_macd == -1 ? 1 : 0) + (sig_rsi == -1 ? 1 : 0) + (sig_di == -1 ? 1 : 0) + (sig_kvo == -1 ? 1 : 0)

anyCrossUp = ta.crossover(macdHist, 0) or ta.crossover(rsiVal, 50) or ta.crossover(diPlus, diMinus) or ta.crossover(kvo, 0)
anyCrossDn = ta.crossunder(macdHist, 0) or ta.crossunder(rsiVal, 50) or ta.crossunder(diPlus, diMinus) or ta.crossunder(kvo, 0)

adxBase = adxVal > i_adxThresh
adxFilter = i_requireADXRising ? (adxBase and adxVal > adxVal[1]) : adxBase

// NTフルシグナル（クロス+スコア+平均足+ADX）
ntFullLong  = scoreLong >= i_minScore and anyCrossUp and haBullish and adxFilter
ntFullShort = scoreShort >= i_minScore and anyCrossDn and haBearish and adxFilter

// NTスコアのみ（クロス不要）
ntScoreLong  = scoreLong >= i_minScore and haBullish
ntScoreShort = scoreShort >= i_minScore and haBearish

// ============================================================
// VM
// ============================================================
stdDev    = ta.stdev(close, i_stdLen)
stdRising = stdDev > stdDev[1]
adxRisingVM = adxVal > adxVal[1]
trendActive = stdRising and adxRisingVM

bbBasis = ta.sma(close, i_bbLen)
bbDev   = i_bbSigma * ta.stdev(close, i_bbLen)
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

var int vmDir = 0
if trendActive and close > bbUpper and vmDir != 1
    vmDir := 1
if trendActive and close < bbLower and vmDir != -1
    vmDir := -1
if vmDir == 1 and close < bbUpper
    vmDir := 0
if vmDir == -1 and close > bbLower
    vmDir := 0

vmBull = vmDir == 1
vmBear = vmDir == -1
vmEntryLong  = vmDir == 1 and vmDir[1] != 1
vmEntryShort = vmDir == -1 and vmDir[1] != -1
vmExitLong   = vmDir == 0 and vmDir[1] == 1
vmExitShort  = vmDir == 0 and vmDir[1] == -1

// ============================================================
// 日足フィルター
// ============================================================
dma = request.security(syminfo.tickerid, "D", ta.sma(close, i_dmaLen))
dmaRising  = request.security(syminfo.tickerid, "D", ta.sma(close, i_dmaLen) > ta.sma(close, i_dmaLen)[1])
dmaFalling = request.security(syminfo.tickerid, "D", ta.sma(close, i_dmaLen) < ta.sma(close, i_dmaLen)[1])

// ============================================================
// 案C: VM点灯 OR NTクロス + LDN16除外 + VT1
// ============================================================
bool vmTrigL = vmEntryLong and ntScoreLong
bool vmTrigS = vmEntryShort and ntScoreShort
bool ntTrigL = ntFullLong and vmBull
bool ntTrigS = ntFullShort and vmBear

longEntry  = (vmTrigL or ntTrigL) and dmaRising  and sessionOK and vixOK
shortEntry = (vmTrigS or ntTrigS) and dmaFalling and sessionOK and vixOK

exitLong  = vmExitLong or ntFullShort
exitShort = vmExitShort or ntFullLong

// ============================================================
// 執行
// ============================================================
if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)

// SL
if strategy.position_size > 0 and i_stopLoss > 0
    strategy.exit("Long SL", "Long", stop=strategy.position_avg_price - i_stopLoss)
if strategy.position_size < 0 and i_stopLoss > 0
    strategy.exit("Short SL", "Short", stop=strategy.position_avg_price + i_stopLoss)

// Exit
if strategy.position_size > 0 and exitLong
    strategy.close("Long", comment="Exit L")
if strategy.position_size < 0 and exitShort
    strategy.close("Short", comment="Exit S")

// ============================================================
// 描画
// ============================================================
bgcolor(vmBull ? color.new(color.green, 85) : vmBear ? color.new(color.red, 85) : na)
bgcolor(dmaRising ? color.new(color.blue, 93) : dmaFalling ? color.new(color.purple, 93) : na)

plot(bbUpper, "BB Upper", color.new(color.red, 50), linewidth=1)
plot(bbBasis, "BB Mid", color.new(color.gray, 50), linewidth=1)
plot(bbLower, "BB Lower", color.new(color.teal, 50), linewidth=1)
plot(dma, "D20 MA", color.new(color.yellow, 30), linewidth=2)

plotshape(longEntry and strategy.position_size <= 0, "Long", shape.arrowup, location.belowbar, color.lime, size=size.tiny)
plotshape(shortEntry and strategy.position_size >= 0, "Short", shape.arrowdown, location.abovebar, color.red, size=size.tiny)

var table t = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(t, 0, 0, "案C+VT1", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "PKG A+LDN16", text_color=color.orange, text_size=size.small)
    table.cell(t, 0, 1, "VR", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(vixRatio, "#.###"), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 2, "VIX", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(vixClose, "#.#"), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 3, "vixOK", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, vixOK ? "✓" : "✗", text_color=vixOK ? color.green : color.red, text_size=size.small)
